# =============================================================================
#  Library AI Agent – Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# =============================================================================

# ── Flask ──────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Note: percent-encode special chars in password (@ → %40)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/library?retryWrites=true&w=majority

# ── IBM Watson NLU ─────────────────────────────────────────────────────────
WATSON_NLU_API_KEY=your-watson-nlu-api-key
WATSON_NLU_URL=https://api.<region>.natural-language-understanding.watson.cloud.ibm.com/instances/<instance-id>

# ── IBM WatsonX AI ─────────────────────────────────────────────────────────
WATSONX_URL=https://<region>.ml.cloud.ibm.com
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── Robo Automation thresholds ─────────────────────────────────────────────
ROBO_HIGH_DEMAND_THRESHOLD=10
ROBO_REORDER_THRESHOLD=15
ROBO_MAX_HOLD_DAYS=14

# ── APScheduler (optional) ─────────────────────────────────────────────────
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_MINUTES=30

# ── Firebase Authentication (optional) ─────────────────────────────────────
# Paste the JSON config from Firebase Console → Project Settings → Web App.
# Inline as a single-line JSON string (double-quotes, no newlines).
# If not set, auth.js runs in demo mode (any email dismisses the login overlay).
FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"..."}
